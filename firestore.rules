rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // User Validator
    function isValidUser() {
      return hasRequiredFields(['uid', 'createdAt', 'unlockedStages']) &&
             request.resource.data.uid is string &&
             request.resource.data.uid.size() > 0 && request.resource.data.uid.size() < 128 &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.unlockedStages is map &&
             (!('email' in request.resource.data) || (request.resource.data.email is string && request.resource.data.email.size() < 256)) &&
             (!('displayName' in request.resource.data) || (request.resource.data.displayName is string && request.resource.data.displayName.size() < 100)) &&
             (!('isAnonymous' in request.resource.data) || request.resource.data.isAnonymous is bool) &&
             (!('lastLoginAt' in request.resource.data) || request.resource.data.lastLoginAt is timestamp);
    }

    // StageRun Validator
    function isValidStageRun() {
      return hasRequiredFields(['uid', 'chapterId', 'stageId', 'status', 'startedAt', 'moveCount']) &&
             request.resource.data.uid is string &&
             request.resource.data.uid.size() > 0 && request.resource.data.uid.size() < 128 &&
             request.resource.data.chapterId is number &&
             request.resource.data.stageId is number &&
             request.resource.data.status in ['completed', 'failed_time', 'skipped', 'abandoned', 'restarted'] &&
             request.resource.data.startedAt is timestamp &&
             request.resource.data.moveCount is number &&
             (!('endedAt' in request.resource.data) || request.resource.data.endedAt is timestamp) &&
             (!('durationMs' in request.resource.data) || request.resource.data.durationMs is number) &&
             (!('firstMoveTimeMs' in request.resource.data) || request.resource.data.firstMoveTimeMs == null || request.resource.data.firstMoveTimeMs is number) &&
             (!('gridSize' in request.resource.data) || request.resource.data.gridSize is number);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "shimyeeun04@gmail.com" && request.auth.token.email_verified == true);
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified();

      match /runs/{runId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidStageRun() && uidUnchanged();
        allow update: if isOwner(userId) && isValidStageRun() && uidNotModified();
      }
    }

    match /{path=**}/runs/{runId} {
      allow read: if isAdmin();
    }
  }
}
